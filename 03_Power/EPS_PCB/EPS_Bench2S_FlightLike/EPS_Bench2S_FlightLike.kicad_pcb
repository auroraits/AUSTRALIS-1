(kicad_pcb
	(version 20221018)
	(generator "pcbnew")
	(general (thickness 1.6))
	(paper "A4")
	(layers
		(0 "F.Cu" signal)
		(31 "B.Cu" signal)
		(32 "B.Adhes" user)
		(33 "F.Adhes" user)
		(34 "B.Paste" user)
		(35 "F.Paste" user)
		(36 "B.SilkS" user)
		(37 "F.SilkS" user)
		(38 "B.Mask" user)
		(39 "F.Mask" user)
		(44 "Edge.Cuts" user)
	)
	(setup (pad_to_mask_clearance 0))
	(net 0 "")
	(net 1 "PV_BUS_P")
	(net 2 "PV_BUS_N")
	(net 3 "VBAT_P")
	(net 4 "VBAT_N")
	(net 5 "+5V")
	(net 6 "+3V3")
	(net 7 "SW_5V_RF_EN")
	(net 8 "SW_3V3_OBC_EN")

	(gr_rect (start 20 20) (end 80 80)
		(stroke (width 0.1) (type solid))
		(fill none)
		(layer "Edge.Cuts")
	)

	(footprint "MountingHole:MountingHole_3.2mm_M3"
		(layer "F.Cu")
		(at 24 24)
		(property "Reference" "H1" (at 0 -4 0) (layer "F.SilkS"))
		(property "Value" "M3" (at 0 4 0) (layer "F.Fab"))
	)
	(footprint "MountingHole:MountingHole_3.2mm_M3"
		(layer "F.Cu")
		(at 76 24)
		(property "Reference" "H2" (at 0 -4 0) (layer "F.SilkS"))
		(property "Value" "M3" (at 0 4 0) (layer "F.Fab"))
	)
	(footprint "MountingHole:MountingHole_3.2mm_M3"
		(layer "F.Cu")
		(at 24 76)
		(property "Reference" "H3" (at 0 -4 0) (layer "F.SilkS"))
		(property "Value" "M3" (at 0 4 0) (layer "F.Fab"))
	)
	(footprint "MountingHole:MountingHole_3.2mm_M3"
		(layer "F.Cu")
		(at 76 76)
		(property "Reference" "H4" (at 0 -4 0) (layer "F.SilkS"))
		(property "Value" "M3" (at 0 4 0) (layer "F.Fab"))
	)

	(footprint "TerminalBlock:TerminalBlock_bornier-2_P5.08mm"
		(layer "F.Cu")
		(at 32 36)
		(property "Reference" "J_PV_IN" (at 0 -5 0) (layer "F.SilkS"))
		(property "Value" "PV_IN" (at 0 5 0) (layer "F.Fab"))
	)
	(footprint "Connector_PinHeader_2.54mm:PinHeader_1x03_P2.54mm_Vertical"
		(layer "F.Cu")
		(at 32 50)
		(property "Reference" "J_BAT_TAPS" (at 0 -3 0) (layer "F.SilkS"))
		(property "Value" "B-/BM/B+" (at 0 8 0) (layer "F.Fab"))
	)
	(footprint "TerminalBlock:TerminalBlock_bornier-2_P5.08mm"
		(layer "F.Cu")
		(at 32 64)
		(property "Reference" "J_VBAT" (at 0 -5 0) (layer "F.SilkS"))
		(property "Value" "VBAT_OUT" (at 0 5 0) (layer "F.Fab"))
	)
	(footprint "TerminalBlock:TerminalBlock_bornier-2_P5.08mm"
		(layer "F.Cu")
		(at 62 36)
		(property "Reference" "J_5V_OUT" (at 0 -5 0) (layer "F.SilkS"))
		(property "Value" "+5V_OUT" (at 0 5 0) (layer "F.Fab"))
	)
	(footprint "TerminalBlock:TerminalBlock_bornier-2_P5.08mm"
		(layer "F.Cu")
		(at 62 50)
		(property "Reference" "J_3V3_OUT" (at 0 -5 0) (layer "F.SilkS"))
		(property "Value" "+3V3_OUT" (at 0 5 0) (layer "F.Fab"))
	)
	(footprint "Connector_PinHeader_2.54mm:PinHeader_1x08_P2.54mm_Vertical"
		(layer "F.Cu")
		(at 62 64)
		(property "Reference" "J_CTRL_TLM" (at 0 -3 0) (layer "F.SilkS"))
		(property "Value" "EN+TP" (at 0 21 0) (layer "F.Fab"))
	)
)
